{
	"name": "docs",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "next build",
		"clean": "rm -rf .next .source out build",
		"dev": "next dev",
		"format": "oxfmt .",
		"lint": "oxlint .",
		"prelint:check": "fumadocs-mdx && next typegen",
		"lint:check": "oxlint --type-aware --type-check .",
		"postinstall": "fumadocs-mdx",
		"pretypecheck": "fumadocs-mdx && next typegen",
		"start": "next start",
		"test": "echo 'No tests configured for docs'",
		"typecheck": "tsc --noEmit",
		"types:check": "pnpm run typecheck"
	},
	"dependencies": {
		"@lorenzopant/tmdb": "workspace:*",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@takumi-rs/image-response": "^0.73.1",
		"@vercel/analytics": "^2.0.0",
		"@vercel/speed-insights": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"framer-motion": "^12.34.3",
		"fumadocs-core": "16.6.5",
		"fumadocs-mdx": "14.2.8",
		"fumadocs-typescript": "^5.1.4",
		"fumadocs-ui": "16.6.5",
		"lucide-react": "^1.7.0",
		"next": "16.1.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.4.1"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.1.18",
		"@types/mdx": "^2.0.13",
		"@types/node": "^25.2.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3"
	}
}
