# Your VALID TMDB Bearer Token (that is the bearer token/jwt, not the api key) should be placed here. You can get it from your TMDB account settings under the "API" section.
TMDB_BEARER_TOKEN=your_access_token_here

# Your Valid TMDB API Key (v3) (normal string) should be placed here. You can get it from your TMDB account settings under the "API" section.
TMDB_API_KEY=your_api_key_here