{
	"name": "@lorenzopant/tmdb",
	"version": "1.17.4",
	"description": "A completely type-safe The Movie Database (TMDB) API wrapper for typescript applications.",
	"keywords": [
		"api",
		"movies",
		"tmdb",
		"typescript"
	],
	"homepage": "https://lorenzopant-tmdb-docs.vercel.app",
	"bugs": {
		"url": "https://github.com/lorenzopant/tmdb/issues"
	},
	"license": "MIT",
	"author": "Lorenzo Pantano",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lorenzopant/tmdb"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./types": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"clean": "rm -rf dist coverage",
		"dev": "tsup --watch",
		"format": "oxfmt .",
		"lint": "oxlint .",
		"lint:check": "oxlint --type-aware --type-check .",
		"test": "pnpm run test:unit",
		"test:unit": "vitest run --exclude '**/*.integration.test.ts'",
		"test:integration": "vitest run integration",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^22.19.11",
		"@vitest/coverage-v8": "^4.0.9",
		"@vitest/ui": "^4.0.10",
		"dotenv": "^16.5.0",
		"release-it": "^19.0.3",
		"release-it-pnpm": "^4.6.6",
		"ts-morph": "^27.0.2",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3",
		"vite": "^7.0.0",
		"vitest": "^4.0.9"
	}
}
