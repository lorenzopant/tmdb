{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": ["TMDB_BEARER_TOKEN", "TMDB_API_KEY"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"clean": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"],
			"cache": false
		},
		"lint:check": {
			"dependsOn": ["^lint:check"],
			"cache": false
		},
		"format": {
			"dependsOn": ["^format"],
			"cache": false
		},
		"test": {
			"dependsOn": ["^test"],
			"cache": false
		},
		"test:unit": {
			"dependsOn": ["^test:unit"],
			"cache": false
		},
		"test:integration": {
			"dependsOn": ["^test:integration"],
			"cache": false
		},
		"test:coverage": {
			"dependsOn": ["^test:coverage"],
			"cache": false
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"cache": false
		}
	}
}
