{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": ["TMDB_BEARER_TOKEN", "TMDB_API_KEY"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"],
			"cache": false
		},
		"format": {
			"dependsOn": ["^format"],
			"cache": false
		},
		"test": {
			"dependsOn": ["^test"],
			"cache": false
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"cache": false
		}
	}
}
